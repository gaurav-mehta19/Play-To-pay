# Upstash Redis — use rediss:// (double-s) for TLS
REDIS_URL=

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_ALL=True
WEB_CONCURRENCY=4
CELERY_CONCURRENCY=4
