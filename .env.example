# ================================================================
# PlayToPay — Environment Variables
#
# LOCAL DEV (no .env needed):
#   docker compose up                          ← uses built-in defaults
#
# PRODUCTION:
#   cp .env.example .env                       ← fill every REQUIRED value
#   docker compose -f docker-compose.prod.yml up -d
#
# Docker Compose automatically loads this file — no extra flags needed.
# Never commit .env to version control.
# ================================================================


# ----------------------------------------------------------------
# Django core
# ----------------------------------------------------------------

# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# False in production — True only for local dev
DEBUG=False

# Comma-separated list of domains Django will accept requests on.
# REQUIRED in production — e.g. api.yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=api.yourdomain.com

DJANGO_SETTINGS_MODULE=config.settings


# ----------------------------------------------------------------
# PostgreSQL
# REQUIRED — point at your managed database (RDS, Supabase, Neon, etc.)
# ----------------------------------------------------------------

DB_NAME=playtopay
# REQUIRED
DB_USER=playtopay_user
# REQUIRED
DB_PASSWORD=
# REQUIRED — hostname or IP of your Postgres instance
DB_HOST=your-db-host.rds.amazonaws.com
DB_PORT=5432


# ----------------------------------------------------------------
# Redis — Celery broker + result backend
# REQUIRED — use a managed Redis (ElastiCache, Upstash, Redis Cloud)
# ----------------------------------------------------------------

# REQUIRED — e.g. redis://default:password@your-redis.upstash.io:6379/0
#             or   rediss://... for TLS
REDIS_URL=


# ----------------------------------------------------------------
# CORS — must exactly match the URL users hit in their browser
# ----------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# REQUIRED — e.g. https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Never True in production
CORS_ALLOW_ALL=False


# ----------------------------------------------------------------
# Frontend — Next.js
# REQUIRED — the public URL of your Django API
# ----------------------------------------------------------------

# REQUIRED — e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com


# ----------------------------------------------------------------
# Gunicorn / Celery worker sizing
# ----------------------------------------------------------------

# Gunicorn worker processes (rule of thumb: 2 × CPU cores + 1)
WEB_CONCURRENCY=4

# Celery worker processes per container
CELERY_CONCURRENCY=4
